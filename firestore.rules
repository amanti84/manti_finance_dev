rules_version = '2';

// Firestore Security Rules - manti_finance_dev
// Principio: ogni utente accede SOLO ai propri dati
// path: /users/{userId}/**
//
// NOTA SICUREZZA: la whitelist email (ant.manti@gmail.com, caterinaisaia29@gmail.com)
// e' applicata a livello di Google Auth (issue #70) - non nelle Firestore rules.
// Le rules Firestore verificano solo autenticazione + ownership per uid.
// Questo pattern e' compatibile con il Firebase Emulator in CI.

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================

    // Verifica che l'utente sia autenticato
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica che l'utente acceda ai propri dati
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Verifica che i dati in scrittura abbiano un timestamp valido
    function hasValidTimestamp() {
      return request.resource.data.keys().hasAll(['updatedAt'])
          && request.resource.data.updatedAt is timestamp;
    }

    // =============================================
    // DATI UTENTE (root document)
    // =============================================
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // =============================================
      // SNAPSHOT MENSILI DEL PATRIMONIO
      // =============================================
      match /snapshots/{snapshotId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // MOVIMENTI / TRANSAZIONI
      // =============================================
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // PORTAFOGLIO INVESTIMENTI
      // =============================================
      match /investments/{investmentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // PAC PAYMENTS (Issue #22)
      // =============================================
      match /pac_payments/{paymentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // CEDOLINI / PAYROLL
      // =============================================
      match /payslips/{payslipId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // AUDIT TRAIL (solo append, no delete/update)
      // collection: 'audit' - allineata con audit.ts service
      // =============================================
      match /audit/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        // Audit log e' immutabile: no update, no delete
        allow update, delete: if false;
      }

      // =============================================
      // DECISION ENGINE
      // =============================================
      match /decisions/{decisionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // PREVIDENZA / FONDI PENSIONE
      // =============================================
      match /funds/{fundId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      match /contributions/{contributionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // CONFIGURAZIONE UTENTE
      // =============================================
      match /config/{configId} {
        allow read, write: if isOwner(userId);
      }

      // =============================================
      // DOCUMENTS (Issue #18)
      // =============================================
      match /documents/{documentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // INBOX ITEMS (Issue #31)
      // =============================================
      match /inboxItems/{itemId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // GOALS (Issue #30)
      // =============================================
      match /goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // ALERTS (Issue #28)
      // =============================================
      match /alerts/{alertId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }

      // =============================================
      // SCENARIOS / WHAT-IF (Issue #27)
      // =============================================
      match /scenarios/{scenarioId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidTimestamp();
        allow update: if isOwner(userId) && hasValidTimestamp();
        allow delete: if isOwner(userId);
      }
    }

    // Blocca tutto il resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
