# ============================================================
# ENVIRONMENT VARIABLES - manti_finance_dev
# Copia questo file in .env.local e compila con i tuoi valori
# NON committare mai .env.local nel repository
# ============================================================

# Firebase Configuration
# Firebase Project: mantifinance (NON manti-finance)
# Ottieni questi valori dalla Firebase Console > Project Settings > Web App
# URL Console: https://console.firebase.google.com/project/mantifinance/settings/general
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=mantifinance.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mantifinance
VITE_FIREBASE_REGION=us-central1
VITE_FIREBASE_STORAGE_BUCKET=mantifinance.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================================
# Firebase Emulator Suite (sviluppo locale)
# Decommentare per usare gli emulatori locali
# ============================================================
# VITE_USE_FIREBASE_EMULATOR=true
# VITE_FIRESTORE_EMULATOR_HOST=localhost
# VITE_FIRESTORE_EMULATOR_PORT=8080
# VITE_AUTH_EMULATOR_HOST=localhost
# VITE_AUTH_EMULATOR_PORT=9099
# VITE_STORAGE_EMULATOR_HOST=localhost
# VITE_STORAGE_EMULATOR_PORT=9199

# ============================================================
# App Configuration
# ============================================================
VITE_APP_ENV=development
# VITE_APP_ENV=production
VITE_ALLOWED_EMAILS=email1@gmail.com,email2@gmail.com
